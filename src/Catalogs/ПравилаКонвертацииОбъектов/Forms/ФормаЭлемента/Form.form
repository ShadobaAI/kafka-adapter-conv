              <name>ИмяОбработчикаПоляПоискаКонтекстноеМеню</name>
              <id>300</id>
              <autoFill>true</autoFill>
            </contextMenu>
            <type>InputField</type>
            <readOnly>true</readOnly>
            <editMode>Enter</editMode>
