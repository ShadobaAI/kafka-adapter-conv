
#Область СлужебныеПроцедурыИФункции

&ИзменениеИКонтроль("ЗаполнитьТаблицыСвойств")
&НаСервере
Процедура кфкЗаполнитьТаблицыСвойств()
	#Удаление
	ДанныеПКО = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.Владелец, "ОбъектКонфигурации, ОбъектФормата, ОбъектКонфигурацииКорреспондент");
	КонвертацияДанныхXDTOВызовСервера.ЗаполнитьСписокСвойствКонфигурации(ТаблицаСвойствКонфигурации,
			Объект.Владелец,
			ДанныеПКО.ОбъектКонфигурации,
			Новый Структура("ЭтоГруппа, Родитель", Истина, ""));
	#КонецУдаления
	#Вставка
	ДанныеПКО = ОбщегоНазначения.ЗначенияРеквизитовОбъекта(Объект.Владелец, "ОбъектКонфигурации, кфкТабличнаяЧасть, ОбъектФормата, ОбъектКонфигурацииКорреспондент");
	Если ЗначениеЗаполнено(ДанныеПКО.кфкТабличнаяЧасть) Тогда
		КонвертацияДанныхXDTOВызовСервера.ЗаполнитьСписокСвойствКонфигурации(ТаблицаСвойствКонфигурации,
			Объект.Владелец,
			ДанныеПКО.ОбъектКонфигурации,
			Новый Структура("ЭтоГруппа, Родитель", Истина, ДанныеПКО.кфкТабличнаяЧасть));
		
	Иначе
		КонвертацияДанныхXDTOВызовСервера.ЗаполнитьСписокСвойствКонфигурации(ТаблицаСвойствКонфигурации,
			Объект.Владелец,
			ДанныеПКО.ОбъектКонфигурации,
			Новый Структура("ЭтоГруппа, Родитель", Истина, ""));
		
	КонецЕсли;
	#КонецВставки
	Если ЭтоКонвертацияXDTO Тогда
		ФильтрСвойствФормата = Новый Структура("ОбъектФормата, ЭтоГруппа, Родитель",  ДанныеПКО.ОбъектФормата, Истина, "");
		КонвертацияДанныхXDTOВызовСервера.ЗаполнитьСписокСвойствФормата(ТаблицаСвойствФормата,
				Объект.Владелец,
				ФильтрСвойствФормата);
	Иначе
		КонвертацияДанныхXDTOВызовСервера.ЗаполнитьСписокСвойствКонфигурации(ТаблицаСвойствКонфигурацииКорреспондент,
			Объект.Владелец,
			ДанныеПКО.ОбъектКонфигурацииКорреспондент,
			Новый Структура("ЭтоГруппа, Родитель, Корреспондент", Истина, "", Истина));

	КонецЕсли;
КонецПроцедуры

#КонецОбласти
